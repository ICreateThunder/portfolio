---
import { getCollection, render } from "astro:content";
import { COLLECTIONS, type CollectionName } from "../../types/content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Head from "../../components/Head.astro";
import Navigation from "../../components/Navigation.astro";
import Prose from "../../components/Prose.astro";

export async function getStaticPaths() {
  const paths = [];

  for (const collection of COLLECTIONS) {
    const entries = await getCollection(collection as CollectionName);

    for (const entry of entries) {
      paths.push({
        params: {
          collection,
          slug: entry.data.slug,
        },
        props: {
          entry,
          collection,
        },
      });
    }
  }

  return paths;
}

const { entry, collection } = Astro.props;
const { title, description, published, image, author, tags } = entry.data;
const { Content } = await render(entry);

const date = new Date(published);
const url = Astro.url.href;
---

<BaseLayout>
  <Head
    slot="head"
    {title}
    {description}
    {url}
    {image}
    type="article"
    siteName="Robert Shalders' Personal Site"
    author={author ?? "Robert Shalders"}
    publishDate={date.toISOString()}
    keywords={tags}
  />
  <main class="h-svh min-h-128 md:p-12 p-8 relative overflow-hidden">
    <div class="flex flex-col-reverse lg:flex-row h-full w-full border-4">
      <Navigation />
      <div class="flex justify-center items-start h-full w-full overflow-y-auto p-4 lg:p-8 animate-fade-in">
        <article class="w-full max-w-2xl">
          <header class="mb-6 border-b border-neutral-700 pb-4">
            <p class="text-xs text-neutral-500 font-mono uppercase tracking-widest mb-2">
              {collection}
            </p>
            <h1 class="text-2xl lg:text-3xl font-bold text-white leading-tight">{title}</h1>
            {description && (
              <p class="mt-2 text-neutral-400 font-light text-sm">{description}</p>
            )}
            <p class="mt-3 text-xs text-neutral-600 font-mono">
              <span class="flicker-a">{String(date.getDate()).padStart(2, "0")}</span>
              <span class="flicker-b">·{String(date.getMonth() + 1).padStart(2, "0")}·</span>
              <span class="flicker-c">{date.getFullYear()}</span>
              {author && <span class="ml-2 text-neutral-500">— {author}</span>}
            </p>
          </header>

          {image && (
            <img src={image} alt={title} class="rounded-sm my-4 w-full object-cover max-h-64 saturate-0 contrast-125" />
          )}

          <Prose>
            <Content />
          </Prose>
        </article>
      </div>
    </div>
    <div class="absolute animated-background -z-10 animate-shift -inset-full"></div>
  </main>
</BaseLayout>
