---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NoSeoHead from "../../components/NoSeoHead.astro";
import Navigation from "../../components/Navigation.astro";
import Drawer from "../../components/Drawer.astro";
import CategoryTabs from "../../components/CategoryTabs.astro";
import { getCollection } from "astro:content";
import { COLLECTIONS, type CollectionName } from "../../types/content";
import { sortByPublished } from "../../utils/articles";

export async function getStaticPaths() {
  return COLLECTIONS.map((collection) => ({ params: { collection } }));
}

const { collection } = Astro.params as { collection: CollectionName };
const articles = sortByPublished(await getCollection(collection));

const labels: Record<CollectionName, string> = {
  newsletters: "Newsletters",
  projects:    "Projects",
  resources:   "Resources",
  tricks:      "Tips & Tricks",
};

const label = labels[collection];


const chipColors: Record<string, string> = {
  newsletters: "text-amber-400 border-amber-400/30",
  projects: "text-cyan-300 border-cyan-300/30",
  resources: "text-indigo-400 border-indigo-400/30",
  tricks: "text-teal-400 border-teal-400/30",
};

const chip = chipColors[collection] ?? "text-neutral-400 border-neutral-400/30";
---

<BaseLayout>
  <NoSeoHead
    slot="head"
    title={label}
    description={`All ${label.toLowerCase()} by Robert Shalders.`}
  />
  <main class="h-svh min-h-128 md:p-12 p-8 relative overflow-hidden">
    <div class="flex flex-col-reverse lg:flex-row h-full w-full border-4 overflow-hidden">
      <Navigation />
      <div
        class="flex flex-col flex-1 min-h-0 w-full border-b-4 sm:border-0 relative"
      >
        <CategoryTabs />

        <!-- Content area + Drawer side-by-side -->
        <div class="flex flex-1 min-h-0 relative">
          <div class="flex-1 h-full overflow-y-auto animate-fade-in">

            {articles.length > 0 ? (
              <div class="flex flex-col gap-3 p-4">
                {articles.map((entry) => {
                  const date = new Date(entry.data.published);
                  const formatted = `${date.getDate().toString().padStart(2, "0")}·${(date.getMonth() + 1).toString().padStart(2, "0")}·${date.getFullYear()}`;

                  return (
                    <a href={`/${collection}/${entry.data.slug}`} class="group">
                      <article class="flex items-center gap-4 p-4 border border-neutral-800 transition-all duration-200 hover:border-teal-400 hover:shadow-[0_0_12px_oklch(78.9%_0.154_211.53_/_0.2)]">
                        <div class="w-14 h-14 md:w-18 md:h-18 overflow-hidden rounded-sm shrink-0">
                          <img
                            class="w-full h-full object-cover object-center saturate-0 contrast-125 brightness-75 transition-all duration-300 group-hover:saturate-100 group-hover:contrast-100 group-hover:brightness-90"
                            src={entry.data.image ?? "/fallback.jpg"}
                            alt={entry.data.title}
                          />
                        </div>
                        <div class="flex-1 min-w-0">
                          <div class="flex items-center gap-2 mb-1 flex-wrap overflow-hidden">
                            <span class={`text-[0.6rem] uppercase tracking-widest border px-1.5 py-0.5 ${chip}`}>
                              {collection}
                            </span>
                            <span class="text-[0.6rem] text-neutral-600">{formatted}</span>
                          </div>
                          <p class="text-sm text-neutral-300 leading-snug transition-colors duration-200 group-hover:text-white">
                            {entry.data.title}
                          </p>
                          {entry.data.description && (
                            <p class="text-xs text-neutral-500 mt-1 line-clamp-2">{entry.data.description}</p>
                          )}
                        </div>
                      </article>
                    </a>
                  );
                })}
              </div>
            ) : (
              <div class="flex flex-col items-center justify-center w-full h-full text-neutral-400 text-center p-8">
                <h2 class="text-2xl font-bold mb-2 flicker-a">SYSTEM ALERT: CONTENT UNAVAILABLE</h2>
                <p class="text-sm flicker-b">No articles detected. Recalibration recommended.</p>
              </div>
            )}
          </div>

          <Drawer tabText="Categories" side="right">
            <ul class="flex flex-col h-full justify-evenly items-center text-xl">
              <li><a href="/articles" class="text-neutral-700 hover:text-black hover:underline">All</a></li>
              <li><a href="/newsletters" class:list={[collection === "newsletters" ? "text-black font-bold underline underline-offset-4" : "text-neutral-700 hover:text-black hover:underline"]}>Newsletters</a></li>
              <li><a href="/projects" class:list={[collection === "projects" ? "text-black font-bold underline underline-offset-4" : "text-neutral-700 hover:text-black hover:underline"]}>Projects</a></li>
              <li><a href="/resources" class:list={[collection === "resources" ? "text-black font-bold underline underline-offset-4" : "text-neutral-700 hover:text-black hover:underline"]}>Resources</a></li>
              <li><a href="/tricks" class:list={[collection === "tricks" ? "text-black font-bold underline underline-offset-4" : "text-neutral-700 hover:text-black hover:underline"]}>Tips &amp; Tricks</a></li>
            </ul>
          </Drawer>
        </div>
      </div>
    </div>
    <div class="absolute animated-background -z-10 animate-shift -inset-full"></div>
  </main>
</BaseLayout>
